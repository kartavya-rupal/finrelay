# =========================
# Application
# =========================
NODE_ENV=development
APP_NAME=FinRelay
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# =========================
# Authentication
# =========================
JWT_SECRET=replace_me_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# If using Clerk/Auth.js later, keep placeholders here.
AUTH_PROVIDER=jwt
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
AUTH_SECRET=

# =========================
# PostgreSQL
# =========================
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=finrelay
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/finrelay

# =========================
# Redis
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379

# =========================
# AWS
# =========================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# SQS
SQS_MAIN_QUEUE_URL=
SQS_DLQ_URL=

# S3
S3_BUCKET_NAME=finrelay-raw-events
S3_REGION=ap-south-1

# ECR
ECR_REGISTRY_URL=

# ECS/Fargate
ECS_CLUSTER_NAME=
ECS_SERVICE_API=
ECS_SERVICE_WORKER=
ECS_SERVICE_DASHBOARD=

# =========================
# Observability
# =========================
OTEL_SERVICE_NAME=finrelay-api
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=prometheus
OTEL_LOGS_EXPORTER=console

PROMETHEUS_ENDPOINT=http://localhost:9090
GRAFANA_URL=http://localhost:3001
LOKI_URL=http://localhost:3100

# =========================
# Analytics
# =========================
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8123
CLICKHOUSE_DB=finrelay_analytics
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# =========================
# Search
# =========================
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# =========================
# Notifications
# =========================
SLACK_WEBHOOK_URL=
ALERT_EMAIL_FROM=
ALERT_EMAIL_TO=

# =========================
# Webhook Security
# =========================
WEBHOOK_SIGNATURE_HEADER=x-webhook-signature
WEBHOOK_TIMESTAMP_HEADER=x-webhook-timestamp
WEBHOOK_ID_HEADER=x-webhook-id

# =========================
# Retry / Queue Behavior
# =========================
MAX_RETRY_ATTEMPTS=5
RETRY_BACKOFF_BASE_MS=1000
RETRY_BACKOFF_MAX_MS=30000
DEDUP_TTL_SECONDS=86400

# =========================
# Misc
# =========================
LOG_LEVEL=info
ENABLE_PAYLOAD_REDACTION=true
ENABLE_REPLAY=true
